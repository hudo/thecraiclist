<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IRL Events</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0f1117;
            --bg-card: #1a1d27;
            --bg-card-hover: #222633;
            --text: #e8e8ed;
            --text-muted: #8b8fa3;
            --border: #2a2d3a;
            --radius: 12px;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
        }

        header {
            border-bottom: 1px solid var(--border);
            padding: 1.25rem 2rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background: rgba(15, 17, 23, 0.8);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        header h1 {
            font-size: 1.3rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1abc9c, #3498db);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        header .logo {
            font-size: 1.5rem;
        }

        main {
            max-width: 1100px;
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        /* Hero */
        .hero {
            text-align: center;
            padding: 3rem 1rem 2rem;
        }

        .hero h2 {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #fff 0%, #8b8fa3 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        /* Category nav chips */
        .category-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            padding: 1rem 0 2.5rem;
            position: sticky;
            top: 62px;
            z-index: 50;
            background: linear-gradient(var(--bg) 60%, transparent);
            padding-bottom: 3rem;
        }

        .category-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.5rem 1rem;
            border-radius: 99px;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .category-chip:hover {
            border-color: var(--chip-color);
            background: color-mix(in srgb, var(--chip-color) 12%, var(--bg-card));
            transform: translateY(-1px);
        }

        .chip-icon {
            font-size: 1rem;
        }

        .chip-count {
            background: var(--border);
            color: var(--text-muted);
            font-size: 0.75rem;
            padding: 0.1rem 0.5rem;
            border-radius: 99px;
        }

        /* Category sections */
        .category-section {
            margin-bottom: 3rem;
            scroll-margin-top: 140px;
        }

        .category-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid var(--accent);
        }

        .category-icon {
            font-size: 1.75rem;
        }

        .category-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            flex: 1;
        }

        .event-count {
            color: var(--text-muted);
            font-size: 0.85rem;
            font-weight: 500;
        }

        .view-all-link {
            display: block;
            text-align: center;
            margin-top: 0.75rem;
            padding: 0.6rem 1rem;
            color: var(--accent);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            transition: all 0.2s;
        }

        .view-all-link:hover {
            background: color-mix(in srgb, var(--accent) 12%, var(--bg-card));
            border-color: var(--accent);
        }

        .category-link {
            color: inherit;
            text-decoration: none;
            transition: color 0.2s;
        }

        .category-link:hover {
            color: var(--accent);
        }

        /* Events grid */
        .events-grid {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .event-card {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.25rem;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            transition: all 0.2s;
            border-left: 3px solid var(--accent);
        }

        .event-card:hover {
            background: var(--bg-card-hover);
            transform: translateX(4px);
        }

        .event-date {
            display: flex;
            flex-direction: column;
            align-items: center;
            min-width: 48px;
            padding: 0.4rem 0.5rem;
            background: color-mix(in srgb, var(--accent) 15%, transparent);
            border-radius: 8px;
        }

        .date-day {
            font-size: 1.3rem;
            font-weight: 700;
            line-height: 1.2;
            color: var(--accent);
        }

        .date-month {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }

        .event-info {
            flex: 1;
            min-width: 0;
        }

        .event-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 0.15rem;
        }

        .event-venue {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .event-link {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--border);
            color: var(--text);
            text-decoration: none;
            font-size: 1.1rem;
            font-weight: 600;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .event-link:hover {
            background: var(--accent);
            color: #fff;
        }

        footer {
            text-align: center;
            padding: 2rem;
            color: var(--text-muted);
            font-size: 0.8rem;
            border-top: 1px solid var(--border);
        }

        @@media (max-width: 600px) {
            .hero h2 {
                font-size: 1.5rem;
            }

            main {
                padding: 1rem 1rem 3rem;
            }

            .event-card {
                padding: 0.75rem 1rem;
            }

            .category-nav {
                top: 56px;
            }
        }
    </style>
</head>
<body>
    <header>
        <span class="logo">☘️</span>
        <h1>The Craic List</h1>
    </header>
    <main>
        @RenderBody()
    </main>
    <footer>
        The Craic List &mdash; Your guide to what's on in Ireland
    </footer>
</body>
</html>
